{
    "name": "apntalk/laravel-freeswitch-esl",
    "description": "Laravel integration and multi-PBX control plane for the APNTalk ESL package family",
    "type": "library",
    "license": "MIT",
    "authors": [
        {
            "name": "APNTalk",
            "email": "dev@apntelecom.com"
        }
    ],
    "keywords": [
        "laravel",
        "freeswitch",
        "esl",
        "pbx",
        "voip",
        "apntalk"
    ],
    "require": {
        "php": "^8.3",
        "apntalk/esl-core": "^0.2",
        "apntalk/esl-react": "^0.2.4",
        "illuminate/console": "^11.0|^12.0",
        "illuminate/contracts": "^11.0|^12.0",
        "illuminate/database": "^11.0|^12.0",
        "illuminate/support": "^11.0|^12.0"
    },
    "require-dev": {
        "orchestra/testbench": "^9.0|^10.0",
        "phpunit/phpunit": "^11.0",
        "phpstan/phpstan": "^1.12",
        "phpstan/phpstan-phpunit": "^1.4",
        "laravel/pint": "^1.18",
        "mockery/mockery": "^1.6"
    },
    "suggest": {
        "apntalk/esl-replay": "Replay-safe capture/store abstractions, replay envelopes, and replay tooling"
    },
    "autoload": {
        "psr-4": {
            "ApnTalk\\LaravelFreeswitchEsl\\": "src/"
        }
    },
    "autoload-dev": {
        "psr-4": {
            "ApnTalk\\LaravelFreeswitchEsl\\Tests\\": "tests/"
        }
    },
    "extra": {
        "laravel": {
            "providers": [
                "ApnTalk\\LaravelFreeswitchEsl\\Providers\\FreeSwitchEslServiceProvider"
            ],
            "aliases": {
                "FreeSwitchEsl": "ApnTalk\\LaravelFreeswitchEsl\\Facades\\FreeSwitchEsl"
            }
        }
    },
    "scripts": {
        "test": "vendor/bin/phpunit",
        "test-unit": "vendor/bin/phpunit --testsuite=Unit",
        "test-integration": "vendor/bin/phpunit --testsuite=Integration",
        "analyse": "vendor/bin/phpstan analyse --no-progress",
        "format": "vendor/bin/pint"
    },
    "minimum-stability": "stable",
    "prefer-stable": true,
    "config": {
        "optimize-autoloader": true,
        "sort-packages": true
    }
}
