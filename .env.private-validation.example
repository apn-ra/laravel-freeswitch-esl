# Copy this file to .env.private-validation on a private-network host before
# running private live validation. Do not commit the filled-in copy.

# Required: private FreeSWITCH ESL endpoint reachable from the validation host.
FREESWITCH_ESL_SMOKE_HOST=pbx.example.internal
FREESWITCH_ESL_SMOKE_PORT=8021
FREESWITCH_ESL_SMOKE_PASSWORD=replace-with-private-secret

# Safety: this wrapper only supports the read-only validation path. Leave true.
FREESWITCH_ESL_SMOKE_READ_ONLY=true

# Optional: event bootstrap timeout in seconds.
FREESWITCH_ESL_SMOKE_TIMEOUT=8

# Optional: retain raw inbound frames alongside the JSON results.
FREESWITCH_ESL_SMOKE_CAPTURE_FRAMES=true

# Optional: where JSON outputs and summaries should be written.
FREESWITCH_ESL_SMOKE_OUTPUT_DIR=build/live-smoke-review

# Transport note:
# The upstream read-only helper currently targets a direct ESL host:port
# endpoint. There is no separate transport flag in this wrapper.
